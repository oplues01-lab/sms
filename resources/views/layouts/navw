aside {
    flex-shrink: 0;
    min-width: 16rem;
    max-width: 16rem;
    width: 16rem;
}

/* Toggle Section Styles */
.toggle-section {
    user-select: none;
    transition: all 0.2s ease;
}

.toggle-section:hover {
    background-color: #f9fafb;
}

.toggle-section:active {
    transform: scale(0.98);
}

/* Section Links Styles */
.section-links {
    display: none;
    overflow: hidden;
    transition: all 0.3s ease-in-out;
    border-left: 2px solid #e5e7eb;
    padding-left: 0.5rem;
}

.section-links.active {
    display: block;
}

/* Toggle Icon Animation */
.toggle-icon {
    transition: transform 0.3s ease;
}

.toggle-icon.rotated {
    transform: rotate(180deg);
}

/* Nav Link Hover Effects */
.section-links x-nav-link:hover {
    background-color: #f3f4f6;
    color: #4f46e5;
}

/* Active Nav Link */
.section-links x-nav-link[active="true"] {
    background-color: #eef2ff;
    color: #4f46e5;
    border-left: 3px solid #4f46e5;
}

/* Custom Scrollbar */
aside nav {
    scrollbar-width: thin;
    scrollbar-color: #d1d5db #f9fafb;
}

aside nav::-webkit-scrollbar {
    width: 5px;
}

aside nav::-webkit-scrollbar-track {
    background: #f9fafb;
}

aside nav::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 10px;
}

aside nav::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
}

/* Smooth Transitions */
* {
    transition-property: background-color, border-color, color, fill, stroke;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
}
</style>

<script>
// Initialize sidebar functionality
function initializeSidebar() {
    // Get all toggle sections
    const toggleSections = document.querySelectorAll('.toggle-section');
    
    // Add click event to each toggle
    toggleSections.forEach(toggle => {
        toggle.addEventListener('click', function(e) {
            e.preventDefault();
            
            const targetId = this.getAttribute('data-target');
            const targetSection = document.getElementById(targetId);
            const icon = this.querySelector('.toggle-icon');
            
            if (targetSection && icon) {
                // Toggle the section
                if (targetSection.classList.contains('active')) {
                    // Close section
                    targetSection.classList.remove('active');
                    icon.classList.remove('rotated');
                } else {
                    // Open section
                    targetSection.classList.add('active');
                    icon.classList.add('rotated');
                }
            }
        });
    });
    
    // Auto-expand section containing active route
    const activeLinks = document.querySelectorAll('x-nav-link[active="true"]');
    activeLinks.forEach(link => {
        const parentSection = link.closest('.section-links');
        if (parentSection) {
            parentSection.classList.add('active');
            const sectionId = parentSection.id;
            const toggleIcon = document.querySelector(`.toggle-section[data-target="${sectionId}"] .toggle-icon`);
            if (toggleIcon) {
                toggleIcon.classList.add('rotated');
            }
        }
    });
}

// Initialize when DOM is loaded
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeSidebar);
} else {
    initializeSidebar();
}
</script>